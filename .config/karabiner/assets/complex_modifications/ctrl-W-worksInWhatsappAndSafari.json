{
    "title": "Control-W → Option-Delete everywhere except Obsidian and Terminal",
    "rules": [
        {
            "description": "Control-W acts as Option-Delete everywhere except Obsidian and Terminal",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "w",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code": "delete_or_backspace",
                            "modifiers": ["option"]
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^md\\.obsidian$",
                                "^com\\.apple\\.Terminal$",
                                "^com\\.apple\\.Preview$"
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "description": "Control-U acts as Command-Delete everywhere except Obsidian and Terminal",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "u",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code": "delete_or_backspace",
                            "modifiers": ["command"]
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^md\\.obsidian$",
                                "^com\\.apple\\.Terminal$",
                                "^com\\.apple\\.Preview$"
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "description": "Control-H acts as Delete everywhere except Obsidian and Terminal",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "h",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code": "delete_or_backspace"
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^md\\.obsidian$",
                                "^com\\.apple\\.Terminal$",
                                "^com\\.apple\\.Preview$"
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "description": "Control-J acts as Carriage Return everywhere except Terminal",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "j",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code": "return_or_enter"
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^com\\.apple\\.Terminal$"
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "description": "Control-, Control-. are arrow keys",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "comma",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code":"down_arrow",
                            "modifiers":[]
                        }
                    ],
                    "conditions": [
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "period",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "key_code": "up_arrow",
                            "modifiers":[]
                        }
                    ],
                    "conditions": [
                    ]
                }
            ]
        }
    ]
}



{
  "title": "Space + 1 opens WezTerm",
  "rules": [
    {
      "description": "Simultaneous Space + 1 → open WezTerm",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              { "key_code": "spacebar" },
              { "key_code": "1" }
            ],
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a terminal"
            }
          ]
        }
      ]
    },
    {
      "description": "Simultaneous Space + 2 → open Safari",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              { "key_code": "spacebar" },
              { "key_code": "2" }
            ],
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a safari"
            }
          ]
        }
      ]
    },
    {
      "description": "Simultaneous Space + 3 → open Preview",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              { "key_code": "spacebar" },
              { "key_code": "3" }
            ],
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a Preview"
            }
          ]
        }
      ]
    },
    {
      "description": "Simultaneous Space + 4 → open Obsidian",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              { "key_code": "spacebar" },
              { "key_code": "4" }
            ],
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a obsidian"
            }
          ]
        }
      ]
    }
  ]
}


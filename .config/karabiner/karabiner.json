{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Hyper+a,s,d,f → open apps (same as Space+1..4)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "a",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a wezterm" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "r",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a safari" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "s",
                                    "modifiers": {
                                        "mandatory": ["command", "control", "option", "shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "shell_command": "open -a Preview" }],
                                "type": "basic"
                            },
                            {
                                "from": {

                                        "bundle_identifiers": [
                                            "^com\\.apple\\.Terminal$",
                                            "^com\\.googlecode\\.iterm2$",
                                            "^org\\.wezfurlong\\.wezterm$",
                                            "^io\\.alacritty$",
                                            "^com\\.microsoft\\.VSCode$"

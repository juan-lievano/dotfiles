                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "open_bracket",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
